{
  "name": "eye-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend da EYE Agência — solicitações, aprovação do CEO e produção",
  "scripts": {
    "dev": "node --experimental-strip-types --experimental-sqlite --watch src/server.ts",
    "start": "node --experimental-strip-types --experimental-sqlite src/server.ts",
    "db:migrate": "node --experimental-strip-types --experimental-sqlite src/db/migrate.ts",
    "db:seed": "node --experimental-strip-types --experimental-sqlite src/db/seed.ts",
    "db:reset": "node --experimental-strip-types --experimental-sqlite src/db/seed.ts --reset",
    "db:reset-transacional": "node --experimental-strip-types --experimental-sqlite src/db/reset-transacional.ts",
    "db:seed-prod": "node --experimental-strip-types --experimental-sqlite src/db/seed-prod.ts",
    "test:smoke": "node --experimental-strip-types --experimental-sqlite scripts/smoke.ts",
    "test:pg": "node --experimental-strip-types scripts/smoke-pg.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.20.0",
    "pg-mem": "^3.0.14",
    "typescript": "^5.5.4"
  }
}
