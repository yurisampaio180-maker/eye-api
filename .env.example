# ============================================================
# EYE Agência — Backend · variáveis de ambiente
# Copie para ".env" e preencha. NÃO versione o .env.
# ============================================================

# Banco de dados (a camada detecta o driver pela URL).
#  - Local fácil (padrão): SQLite embutido
DATABASE_URL="file:./dev.db"
#  - Produção GRÁTIS: Postgres do Supabase (cole a "Connection string > URI"):
# DATABASE_URL="postgresql://postgres:SUA_SENHA@db.SEU_REF.supabase.co:5432/postgres"

# Porta do servidor e origem do front (CORS)
PORT=3333
CORS_ORIGIN="http://localhost:5190"

# JWT — gere segredos longos e aleatórios (NÃO use estes valores).
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="troque-isto-por-um-segredo-aleatorio-longo"
JWT_REFRESH_SECRET="troque-isto-por-outro-segredo-aleatorio-longo"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Upload de arquivos (referências/entregas)
UPLOAD_DIR="./uploads"

# OpenAI (geração de prompt/legenda/roteiro) — opcional
OPENAI_API_KEY=""

# Senha padrão dos usuários de teste criados pelo seed
SEED_DEFAULT_PASSWORD="eye123"

# Supabase Storage — para imagens geradas pela IA (obrigatório em produção)
# Passo a passo:
#   1. supabase.com → seu projeto → Storage → New Bucket
#   2. Nome: eye-imagens | marcar "Public" | Create
#   3. Project Settings → API → copiar Project URL e service_role key
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
